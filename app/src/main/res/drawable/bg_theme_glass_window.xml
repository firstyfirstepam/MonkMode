<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="#F5FFFFFF"
                android:startColor="#E8FFECB3"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:bottom="0dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:centerColor="#00FFFFFF"
                android:endColor="#1AFFFFFF"
                android:startColor="#40FFF9C4"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
