<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Default / classic purple + light surfaces -->
    <style name="Theme.ReelCounter.Purple" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_700</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:colorBackground">@color/friction_bg</item>
        <item name="colorSurface">@color/friction_card</item>
        <item name="colorOnSurface">@color/friction_text_primary</item>
        <item name="android:textColorPrimary">@color/friction_text_primary</item>
        <item name="android:textColorSecondary">@color/friction_muted</item>
        <item name="reelCardStrokeColor">#33000000</item>
    </style>

    <!-- Glassmorphic warm yellow / white -->
    <style name="Theme.ReelCounter.GlassSun" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/theme_glass_primary_dark</item>
        <item name="colorPrimaryVariant">@color/theme_glass_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/theme_glass_primary</item>
        <item name="colorSecondaryVariant">#FFFFC107</item>
        <item name="colorOnSecondary">@color/theme_glass_on_surface</item>
        <item name="android:statusBarColor">@color/theme_glass_primary_dark</item>
        <item name="android:navigationBarColor">#E8FFF8E1</item>
        <item name="android:windowBackground">@drawable/bg_theme_glass_window</item>
        <item name="android:colorBackground">#FFFFFDE7</item>
        <item name="colorSurface">#E6FFFFFF</item>
        <item name="colorOnSurface">@color/theme_glass_on_surface</item>
        <item name="android:textColorPrimary">@color/theme_glass_on_surface</item>
        <item name="android:textColorSecondary">#B33E2723</item>
        <item name="reelCardStrokeColor">#59F57F17</item>
    </style>

    <!-- Violet + black, white text -->
    <style name="Theme.ReelCounter.VioletNight" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/theme_violet_primary</item>
        <item name="colorPrimaryVariant">@color/theme_violet_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/theme_violet_accent_soft</item>
        <item name="colorSecondaryVariant">@color/theme_violet_accent_soft</item>
        <item name="colorOnSecondary">@color/theme_violet_bg</item>
        <item name="android:statusBarColor">@color/theme_violet_bg</item>
        <item name="android:navigationBarColor">@color/theme_violet_bg</item>
        <item name="android:windowBackground">@color/theme_violet_bg</item>
        <item name="android:colorBackground">@color/theme_violet_bg</item>
        <item name="colorSurface">@color/theme_violet_surface</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">#B3FFFFFF</item>
        <item name="reelCardStrokeColor">#66806ADB</item>
    </style>

    <style name="Theme.ReelCounter" parent="Theme.ReelCounter.Purple" />

    <style name="TextAppearance.Usage.Tab" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
